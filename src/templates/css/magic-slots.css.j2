/* ===== GENERATED from items.json — edit the .j2, not the output. =====
   The right page of the magic book: 20 fixed slots, one per known rune,
   filled reading-order (top-left, across, then down a row) as the player
   consumes runes. Icons render at their native magicbook-artwork size minus
   a quarter (~120×178px average source → 5.76% × 13.27% of the 1563×1006
   ARX-MAGICBOOK.png container, ×0.75). 5 columns × 4 rows, pitch spread to
   fill the right page's width/height. Origin/pitch are a first pass over
   the right page's blank parchment — expect a visual tuning pass. */

{% set sb_cols = 5 %}
{% set sb_ox, sb_oy = 53.0, 8.0 %}
{% set sb_px, sb_py = 7.3, 20.5 %}
{% set sb_w, sb_h = 5.76, 13.27 %}
{% for i in range(20) %}
.sheet-spellbook-slot--{{ i + 1 }} {
  left: {{ "%.2f" | format(sb_ox + (i % sb_cols) * sb_px) }}%;
  top: {{ "%.2f" | format(sb_oy + (i // sb_cols) * sb_py) }}%;
}
{% endfor %}

.sheet-spellbook-slot {
  position: absolute;
  width: {{ sb_w }}%;
  height: {{ sb_h }}%;
  cursor: url('{{ "{{ASSET_BASE}}" }}/points-hover.png') 4 4, help;
}

/* Fill the slot box exactly (no 80%/10% inset) — the box IS the target icon size. */
.sheet-spellbook-slot .sheet-item-icon {
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

/* Reuses .sheet-item-icon's base display:none (defined in inventory-slots.css.j2);
   only the reveal + magicbook artwork are scoped to this page, so a rune's
   OWN icon rule (used in the bag) never leaks in here. */
{% for item_id, item in items.items() %}
{% if item.effect | default("") == "rune" %}
.sheet-spellbook-slot input[value="{{ item_id }}"] + .sheet-item-icon {
  display: block;
  background-image: url('{{ "{{ASSET_BASE}}" }}/{{ item.icon | replace("item-rune-", "item-magicbook-") }}');
}
{% endif %}
{% endfor %}

/* Rune name on hover — yellow with a star, distinct from the regular white
   item billboard (and shown only while hovering the SPELLBOOK slot, not the
   rune in the bag). */
.sheet-spell-statbar {
  color: #ffd700;
  text-shadow: 0 0 3px rgba(0, 0, 0, 0.9), 0 1px 2px rgba(0, 0, 0, 0.9);
}
{% for item_id, item in items.items() %}
{% if item.effect | default("") == "rune" %}
.sheet-arx:has(.sheet-spellbook-slot:hover input[value="{{ item_id }}"]) .sheet-statbar--spell-{{ item_id }} {
  display: block;
}
{% endif %}
{% endfor %}

/* The grimoire: a modest drop-target on the LEFT page (the right page is now
   filled almost edge-to-edge by the 20-slot grid). Placed below the knotwork
   art, clear of the numbered page tabs on the left edge. */
.sheet-grimoire {
  position: absolute;
  left: 15%;
  top: 88%;
  width: 30%;
  height: 7%;
  padding: 0;
  border: none;
  background: transparent;
  cursor: url('{{ "{{ASSET_BASE}}" }}/base-hover-2.png') 6 4, pointer;
  border-radius: 8px;
  transition: background 0.35s ease-out, box-shadow 0.35s ease-out;
}

/* Glows when holding any rune. */
input[name="attr_hand_effect"][value="rune"] ~ .sheet-book .sheet-grimoire {
  background: radial-gradient(circle, rgba(255, 232, 160, 0.4), rgba(255, 232, 160, 0) 75%);
  box-shadow: 0 0 14px rgba(255, 220, 130, 0.8);
}

/* ---- Spell-page navigation: ARX-MAGICBOOK.png no longer bakes the numbered
   tabs into the artwork, so magic-nav-N.png IS the tab now (always drawn,
   not just on hover). A tab only appears once at least one spell exists on
   that page — page 1 is always shown (it's the entry point) even if empty. ---- */
.sheet-spell-page-radio { display: none; }
.sheet-spell-page-tab {
  display: none;
  position: absolute;
  left: 1.6%;
  width: 7.2%;
  height: 5.5%;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  cursor: url('{{ "{{ASSET_BASE}}" }}/base-hover-2.png') 6 4, pointer;
  transition: filter 0.2s ease-out, box-shadow 0.2s ease-out;
}
.sheet-spell-page-tab:hover {
  filter: brightness(1.3);
  box-shadow: 0 0 10px rgba(255, 220, 130, 0.85);
}
.sheet-spell-page-tab--1 { display: block; } /* always visible, even with no spell yet */
{% set pages_with_spells = spells.values() | map(attribute="page") | unique | list %}
{% for p in range(1, 11) %}
.sheet-spell-page-tab--{{ p }} { background-image: url('{{ "{{ASSET_BASE}}" }}/magic-nav-{{ p }}.png'); }
{% if p in pages_with_spells %}
.sheet-spell-page-tab--{{ p }} { display: block; }
{% endif %}
{% endfor %}
.sheet-spell-page-tab--1  { top: 12.5%; }
.sheet-spell-page-tab--2  { top: 19.0%; }
.sheet-spell-page-tab--3  { top: 27.5%; }
.sheet-spell-page-tab--4  { top: 34.0%; }
.sheet-spell-page-tab--5  { top: 45.0%; }
.sheet-spell-page-tab--6  { top: 53.0%; }
.sheet-spell-page-tab--7  { top: 59.5%; }
.sheet-spell-page-tab--8  { top: 65.0%; }
.sheet-spell-page-tab--9  { top: 72.0%; }
.sheet-spell-page-tab--10 { top: 85.0%; }

/* ---- The 4 fixed spell-slot positions on the left page: a 2×2 grid
   (1=top-left, 2=top-right, 3=bottom-left, 4=bottom-right) centered on the
   page's middle, with generous blank margin above and below. First pass —
   expect a tuning pass once real spell art exists. ---- */
.sheet-spell-slot {
  display: none;
  position: absolute;
  width: 17%;
  height: 25%;
  color: #2b1d0e;
  font-size: 12px;
  text-align: center;
}
.sheet-spell-slot--slot-1 { left: 8%;  top: 22%; }
.sheet-spell-slot--slot-2 { left: 30%; top: 22%; }
.sheet-spell-slot--slot-3 { left: 8%;  top: 53%; }
.sheet-spell-slot--slot-4 { left: 30%; top: 53%; }

.sheet-spell-icon {
  display: block;
  width: 100%;
  height: 100%;
  background-size: contain; /* the spell's own image, at its own proportions */
  background-repeat: no-repeat;
  background-position: center;
}
{% for spell_id, spell in spells.items() %}
{% if spell.icon %}
.sheet-spell-slot--{{ spell_id }} .sheet-spell-icon {
  background-image: url('{{ "{{ASSET_BASE}}" }}/{{ spell.icon }}');
}
{% endif %}
{% endfor %}

/* A spell shows only on its assigned page, once every rune it requires is
   known — one :has() per condition composes as AND regardless of where in
   the tree each piece (radio, known-flag mirror) actually lives. */
{% for spell_id, spell in spells.items() %}
.sheet-arx:has(input[name="attr_spell_page"][value="{{ spell.page }}"]:checked){% for rune in spell.runes %}:has(input[name="attr_known_{{ rune[5:] }}"][value="1"]){% endfor %} .sheet-spell-slot--{{ spell_id }} {
  display: block;
}
{% endfor %}
