{# Page navigation: one radio per page, saved per character via attr_sheet_tab.
   CSS in src/css/tabs.css shows the page matching the checked radio.
   To add a page: add a radio here, a partial in partials/pages/, its CSS files
   in src/css/pages/, and the matching rules in tabs.css. #}
<input type="radio" class="sheet-tab-radio sheet-tab-radio--base" name="attr_sheet_tab" value="base" checked="checked" />
{# Navigation ribbons pinned on the left page's top edge — visual only for now,
   they will drive attr_sheet_tab once their pages exist. #}
<div class="sheet-nav-btn sheet-nav--magic"></div>
<div class="sheet-nav-btn sheet-nav--map"></div>
<div class="sheet-nav-btn sheet-nav--questions"></div>
