{# Page navigation: one radio per page, saved per character via attr_sheet_tab.
   Ribbons are <label>s wired to their radio's id — pure HTML/CSS, no worker
   needed to switch pages. CSS in src/css/tabs.css shows the page + ribbon set
   matching the checked radio; the .sheet-book background swap lives there too.
   To add a page: add a radio + label here, a partial in partials/pages/, its
   CSS in src/css/pages/, and the matching rules in tabs.css. #}
<input type="radio" id="sheet-tab-base" class="sheet-tab-radio sheet-tab-radio--base" name="attr_sheet_tab" value="base" checked="checked" />
<input type="radio" id="sheet-tab-magic" class="sheet-tab-radio sheet-tab-radio--magic" name="attr_sheet_tab" value="magic" />
<label for="sheet-tab-magic" class="sheet-nav-btn sheet-nav--magic"></label>
<label for="sheet-tab-base" class="sheet-nav-btn sheet-nav--base"></label>
<div class="sheet-nav-btn sheet-nav--map"></div>
<div class="sheet-nav-btn sheet-nav--questions"></div>
