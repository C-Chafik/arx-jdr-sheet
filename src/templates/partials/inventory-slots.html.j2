{# Bag slots (cols × rows from build.py), row-major numbering.
   The band's rightmost stitched column is the pouch — not a storage cell. #}
{% for i in range(1, cols * rows + 1) %}
  <div class="sheet-slot sheet-slot--bag_{{ i }}">
    <input type="hidden" name="attr_bag_{{ i }}" value="" />
    <span class="sheet-item-icon"></span>
    <button type="action" name="act_slot_bag_{{ i }}"></button>
  </div>
{% endfor %}
