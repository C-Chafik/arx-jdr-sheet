{# Bag slots (cols × rows × bags levels from build.py), row-major numbering.
   Level L holds cells (L-1)*cols*rows+1 … L*cols*rows; only the level matching
   attr_bag_level is displayed (CSS). The band's rightmost stitched column is
   the pouch: consuming an "extra_bag" item there unlocks the next level. #}
{% set per_level = cols * rows %}
{% for i in range(1, per_level * bags + 1) %}
{% set level = ((i - 1) // per_level) + 1 %}
{% set cell = (i - 1) % per_level %}
  <div class="sheet-slot sheet-slot--bag_{{ i }} sheet-bag-cell-{{ cell }} sheet-bag-level-{{ level }}">
    <input type="hidden" name="attr_bag_{{ i }}" value="" />
    <span class="sheet-item-icon"></span>
    <button type="action" name="act_slot_bag_{{ i }}"></button>
  </div>
{% endfor %}
  {# The pouch: drop an extra_bag item here to unlock the next level. #}
  <button type="action" class="sheet-pouch" name="act_slot_pouch"></button>
  {# Level navigation arrows, living on the pouch. #}
  <button type="action" class="sheet-bag-nav sheet-bag-nav--up" name="act_bag_up"></button>
  <button type="action" class="sheet-bag-nav sheet-bag-nav--down" name="act_bag_down"></button>
