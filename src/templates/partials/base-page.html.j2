{% set attributes = ["strength", "mental", "dexterity", "constitution"] %}
{% set skills = ["stealth", "technical", "intuition",
                 "ethereal_link", "object_knowledge", "casting",
                 "close_combat", "projectile", "defense"] %}
{% set gauges = ["health", "mana"] %}
{% set singles = ["armor_class", "magic_resistance", "poison_resistance", "damages"] %}
<div class="sheet-arx sheet-base-page">
  <div class="sheet-field sheet-field--level">
    <input type="number" name="attr_level" value="1" />
  </div>
{% for name in attributes + skills + singles %}
  <div class="sheet-field sheet-field--{{ name }}">
    <input type="number" name="attr_{{ name }}" value="0" />
  </div>
{% endfor %}
{% for name in gauges %}
  <div class="sheet-field sheet-gauge sheet-field--{{ name }}">
    <input type="number" name="attr_{{ name }}" value="0" />
    <span class="sheet-gauge-sep">/</span>
    <input type="number" name="attr_{{ name }}_max" value="0" />
  </div>
{% endfor %}
</div>
