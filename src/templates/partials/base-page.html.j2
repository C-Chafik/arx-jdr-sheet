{% set attributes = ["strength", "mental", "dexterity", "constitution"] %}
{% set skills = ["stealth", "technical", "intuition",
                 "ethereal_link", "object_knowledge", "casting",
                 "close_combat", "projectile", "defense"] %}
{% set gauges = ["health", "mana"] %}
{% set singles = ["armor_class", "magic_resistance", "poison_resistance", "damages"] %}
<div class="sheet-arx sheet-base-page">
  <div class="sheet-field sheet-field--level">
    <input type="number" name="attr_level" value="1" />
  </div>
{% for name in attributes + skills + singles %}
  <div class="sheet-field sheet-field--{{ name }}">
    <input type="number" name="attr_{{ name }}" value="0" />
  </div>
{% endfor %}
{% for name in gauges %}
  <div class="sheet-field sheet-gauge sheet-field--{{ name }}">
    <input type="number" name="attr_{{ name }}" value="0" />
    <span class="sheet-gauge-sep">/</span>
    <input type="number" name="attr_{{ name }}_max" value="0" />
  </div>
{% endfor %}
  {# Hover descriptions — EDIT THE TEXTS HERE. One entry per icon: (name, label, description).
     The matching zone coordinates live in src/css/hover.css under .sheet-hover--<name>. #}
{% set stat_infos = [
    ("strength",          "Force",                    "La puissance physique brute du personnage."),
    ("mental",            "Mental",                   "L'acuité intellectuelle et la volonté."),
    ("dexterity",         "Dextérité",                "L'adresse, la précision et les réflexes."),
    ("constitution",      "Constitution",             "L'endurance et la résistance du corps."),
    ("stealth",           "Furtivité",                "L'art de se déplacer sans être vu ni entendu."),
    ("technical",         "Mécanique",                "La maîtrise des mécanismes, pièges et machines."),
    ("intuition",         "Intuition",                "Percevoir l'invisible et sentir le danger."),
    ("ethereal_link",     "Lien psychique",           "Le lien avec l'éther et les esprits."),
    ("object_knowledge",  "Compétence manuelle",      "L'habileté dans les travaux manuels délicats."),
    ("casting",           "Magie",                    "L'art de canaliser et lancer des sorts."),
    ("close_combat",      "Combat au corps à corps",  "L'efficacité au corps à corps."),
    ("projectile",        "Projectile",               "La précision des attaques à distance."),
    ("defense",           "Défense",                  "L'art de bloquer, parer et esquiver."),
    ("armor_class",       "Classe d'armure",          "La protection offerte par l'armure."),
    ("magic_resistance",  "Résistance à la magie",    "La résistance aux effets magiques."),
    ("poison_resistance", "Résistance au poison",     "La résistance aux poisons et toxines."),
    ("health",            "Santé",                    "Les points de vie actuels et maximum."),
    ("mana",              "Mana",                     "La réserve d'énergie magique, actuelle et maximum."),
    ("damages",           "Dégâts",                   "Les dégâts infligés par l'attaque équipée."),
] %}
{% for name, label, text in stat_infos %}
  <div class="sheet-hover-zone sheet-hover--{{ name }}"></div>
  <div class="sheet-statbar sheet-statbar--{{ name }}">{{ label }} &mdash; {{ text }}</div>
{% endfor %}
</div>
