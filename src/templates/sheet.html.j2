<div class="sheet-arx">
  {# Hand state mirrors: MUST stay before .sheet-book and .sheet-inventory so
     sibling CSS (~) can reach the slots in both containers. #}
  <input type="hidden" class="sheet-hand-mirror" name="attr_hand" value="" />
  <input type="hidden" class="sheet-hand-mirror" name="attr_hand_from" value="" />
  <input type="hidden" class="sheet-hand-mirror" name="attr_hand_cat" value="" />
  <input type="hidden" class="sheet-hand-mirror" name="attr_hand_effect" value="" />
  <input type="hidden" class="sheet-hand-mirror" name="attr_fit" value="" />
  {# Bag levels: count = unlocked, level = currently displayed. DOM order matters:
     bag_count BEFORE bag_level (nav visibility selectors chain them with ~). #}
  <input type="hidden" class="sheet-hand-mirror" name="attr_bag_count" value="1" />
  <input type="hidden" class="sheet-hand-mirror" name="attr_bag_level" value="1" />
  {# Known-rune flags: one per rune (attr_known_<suffix>, suffix = id minus
     "rune-"), set permanently once learned via the grimoire. Spell visibility
     (magic-slots.css.j2) reaches these through :has(), so position doesn't
     matter the way it does for the sibling-selector mirrors above. #}
{% for item_id, item in items.items() %}
{% if item.effect | default("") == "rune" %}
  <input type="hidden" class="sheet-hand-mirror" name="attr_known_{{ item_id[5:] }}" value="" />
{% endif %}
{% endfor %}
  {# Inventory toggle: always visible, whatever the active page. State saved per character. #}
  <input type="checkbox" class="sheet-inventory-toggle" name="attr_inventory_open" value="1" />
  <div class="sheet-book">
{% include "partials/tabs.html.j2" %}
{% include "partials/pages/base.html.j2" %}
{% include "partials/pages/magic.html.j2" %}
  {# Item names on hover — same billboard as the stat descriptions.
     Revealed by generated :has() rules in css/inventory-slots.css.j2.
     Legendary items get a star marker ahead of their name. #}
{% for item_id, item in items.items() %}
    <div class="sheet-statbar sheet-statbar--item-{{ item_id }}">{% if item.legendary | default(false) %}★ {% endif %}{{ item.label }}</div>
{% endfor %}
  {# Learned-rune names on hover (magic page only) — yellow with a star,
     revealed by :has() rules in css/magic-slots.css.j2. #}
{% for item_id, item in items.items() %}
{% if item.effect | default("") == "rune" %}
    <div class="sheet-statbar sheet-spell-statbar sheet-statbar--spell-{{ item_id }}">★ {{ item.label }}</div>
{% endif %}
{% endfor %}
  {# Known-spell names on hover (2x2 cast slots) — same yellow billboard as
     learned runes but no star (only runes and secret presets get one),
     revealed by :has() rules in css/magic-slots.css.j2. #}
{% for spell_id, spell in spells.items() %}
    <div class="sheet-statbar sheet-spell-statbar sheet-statbar--cast-{{ spell_id }}">{{ spell.label }}</div>
{% endfor %}
  {# Memorized-spell (preset) names on hover — same yellow as the book's
     spells, no star; a secret spell (no book entry) reads red WITH a star
     instead, revealed by :has() rules in css/magic-slots.css.j2.
     presets.json is self-contained (label + runes + icon), even for
     book-linked spells — so it doubles as the catalog used later to detect
     rune combinations. #}
{% for preset_id, preset in presets.items() %}
    <div class="sheet-statbar sheet-preset-statbar{% if preset.secret %} sheet-preset-statbar--secret{% endif %} sheet-statbar--preset-{{ preset_id }}">{% if preset.secret %}★ {% endif %}{{ preset.label }}</div>
{% endfor %}
  </div>
  {# The leather band slides out from under the book when the toggle is checked. #}
  <div class="sheet-inventory">
{% include "partials/inventory-slots.html.j2" %}
  </div>
</div>
